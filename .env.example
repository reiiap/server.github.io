# MySQL connection used by /api/auth/login to read LuckPerms and verification tokens.
MYSQL_DATABASE_URL="mysql://user:password@host:3306/database"
MYSQL_SSL="true"

# At least 32 characters. Used to sign secure HTTP-only login sessions.
AUTH_SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional table containing uuid, balance, playtime columns.
PLAYER_STATS_TABLE="voxensmp_player_stats"
